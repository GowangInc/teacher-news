# Copy to .env and fill in for local generation.
# DO NOT commit your real API key to git.

# DeepSeek example (or any OpenAI-compatible API):
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# Optional generation settings:
TOP_N=10
MAX_AGE_HOURS=12
MAX_TOP_LEVEL=50
MAX_REPLIES_PER_NODE=3
MAX_DEPTH=3
BATCH_SIZE=25
COMMENT_TRUNCATE=600
